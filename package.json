{
  "name": "ledge-app",
  "version": "0.6.0",
  "author": "olllayor",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.11.1",
  "description": "Ledge is a macOS-only shelf utility built with Electron and Swift.",
  "main": "out/main/index.cjs",
  "scripts": {
    "clean:build": "node scripts/clean-build.mjs",
    "clean:dist": "node scripts/clean-dist.mjs",
    "dev": "pnpm brand:build && pnpm native:build && electron-vite dev",
    "build": "pnpm clean:build && pnpm brand:build && pnpm native:build && electron-vite build",
    "preview": "pnpm brand:build && pnpm native:build && electron-vite preview",
    "lint": "tsc --noEmit -p tsconfig.json && tsc --noEmit -p tsconfig.node.json && tsc --noEmit -p convex/tsconfig.json",
    "test": "vitest run && pnpm native:test",
    "test:watch": "vitest",
    "video:studio": "pnpm --dir release-video video:studio",
    "video:render": "pnpm --dir release-video video:render",
    "video:still": "pnpm --dir release-video video:still",
    "landing:dev": "vite landing --host 0.0.0.0",
    "landing:build": "vite build landing --outDir ../dist/landing --emptyOutDir",
    "landing:preview": "vite preview dist/landing --host 0.0.0.0",
    "brand:build": "node scripts/build-brand.mjs",
    "changelog:update": "node scripts/build-changelog.mjs \"${1:-HEAD~1}\" HEAD",
    "changelog:diff": "node scripts/build-changelog.mjs --dry-run \"${1:-HEAD~1}\" HEAD",
    "native:build": "node scripts/build-native.mjs",
    "native:test": "swift run --package-path native/DropShelfNativeAgent DropShelfNativeAgent --self-test",
    "size:report": "node scripts/size-report.mjs",
    "dist": "pnpm clean:dist && pnpm build && node scripts/build-electron-lean.mjs && pnpm size:report",
    "dist:release": "pnpm clean:dist && pnpm build && node scripts/build-electron-lean.mjs --dir && node scripts/build-dmg.mjs && pnpm size:report",
    "release": "node scripts/release.mjs",
    "release:dry": "node scripts/release.mjs patch --dry-run",
    "release:notes": "node scripts/release-notes.mjs",
    "convex:dev": "convex dev",
    "convex:codegen": "convex codegen"
  },
  "devDependencies": {
    "@edge-runtime/vm": "^5.0.0",
    "@electron/asar": "4.2.0",
    "@testing-library/react": "^16.3.2",
    "@types/node": "25.5.0",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "5.2.0",
    "convex-test": "^0.0.53",
    "electron": "41.2.0",
    "electron-builder": "26.9.0",
    "electron-vite": "5.0.0",
    "happy-dom": "^20.10.3",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "typescript": "7.0.2",
    "vite": "7.3.1",
    "vitest": "4.1.2",
    "zod": "4.3.6"
  },
  "build": {
    "appId": "com.ollayor.ledge",
    "productName": "Ledge",
    "executableName": "Ledge",
    "electronVersion": "41.2.0",
    "files": [
      "out/**/*",
      "package.json",
      "!node_modules/**",
      "!**/*.map",
      "!**/*.test.*",
      "!**/*.spec.*",
      "!**/tests/**",
      "!**/__tests__/**",
      "!**/test-data/**",
      "!**/docs/**",
      "!**/README*",
      "!**/src/**"
    ],
    "extraResources": [
      {
        "from": "native/bin/DropShelfNativeAgent",
        "to": "native/DropShelfNativeAgent"
      }
    ],
    "mac": {
      "icon": "build/app.icns",
      "category": "public.app-category.productivity",
      "target": [
        "dmg",
        "zip"
      ],
      "artifactName": "${productName}-${version}-${arch}.${ext}",
      "hardenedRuntime": true,
      "extendInfo": {
        "CFBundleDisplayName": "Ledge",
        "CFBundleName": "Ledge"
      },
      "electronLanguages": [
        "en"
      ]
    },
    "compression": "maximum",
    "asar": {
      "smartUnpack": true
    },
    "asarUnpack": [
      "**/native/DropShelfNativeAgent"
    ],
    "npmRebuild": false,
    "nodeGypRebuild": false
  },
  "dependencies": {
    "clsx": "^2.1.1",
    "convex": "^1.38.0",
    "tailwind-merge": "^3.6.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "electron",
      "electron-winstaller",
      "esbuild"
    ]
  }
}
